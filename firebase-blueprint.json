{
  "entities": {
    "PrivateUser": {
      "title": "PrivateUser",
      "description": "Private user data including PII and settings.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "phoneNumber": { "type": "string" },
        "displayName": { "type": "string" },
        "realName": { "type": "string" },
        "photoURL": { "type": "string" },
        "bio": { "type": "string" },
        "country": { "type": "string" },
        "city": { "type": "string" },
        "sex": { "type": "string" },
        "age": { "type": "number" },
        "hidePhoneNumber": { "type": "boolean" },
        "hideCountry": { "type": "boolean" },
        "hideAge": { "type": "boolean" },
        "hideRealName": { "type": "boolean" },
        "role": { "type": "string", "enum": ["user", "admin"] },
        "isBlocked": { "type": "boolean" },
        "tokens": { "type": "number" },
        "isProfileComplete": { "type": "boolean" },
        "isOnline": { "type": "boolean" },
        "lastSeen": { "type": "string", "format": "date-time" },
        "adCategoryPreference": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "createdAt", "role", "isBlocked", "tokens"]
    },
    "PublicProfile": {
      "title": "PublicProfile",
      "description": "Publicly visible user profile.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "displayName": { "type": "string" },
        "realName": { "type": "string" },
        "photoURL": { "type": "string" },
        "bio": { "type": "string" },
        "city": { "type": "string" },
        "sex": { "type": "string" },
        "country": { "type": "string" },
        "phoneNumber": { "type": "string" },
        "age": { "type": "number" },
        "role": { "type": "string", "enum": ["user", "admin"] },
        "isBlocked": { "type": "boolean" },
        "tokens": { "type": "number" },
        "isProfileComplete": { "type": "boolean" },
        "isOnline": { "type": "boolean" },
        "lastSeen": { "type": "string", "format": "date-time" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "displayName", "createdAt", "role", "isBlocked", "tokens"]
    },
    "Post": {
      "title": "Post",
      "description": "A life lesson shared by a user.",
      "type": "object",
      "properties": {
        "authorId": { "type": "string" },
        "authorName": { "type": "string" },
        "authorPhoto": { "type": "string" },
        "content": { "type": "string" },
        "mediaUrl": { "type": "string" },
        "mediaType": { "type": "string" },
        "tags": { "type": "array", "items": { "type": "string" } },
        "likesCount": { "type": "number" },
        "commentsCount": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" },
        "lastModifiedAt": { "type": "string", "format": "date-time" },
        "isAIModerated": { "type": "boolean" }
      },
      "required": ["authorId", "authorName", "content", "likesCount", "commentsCount", "createdAt", "isAIModerated"]
    },
    "Comment": {
      "title": "Comment",
      "description": "A comment on a post.",
      "type": "object",
      "properties": {
        "postId": { "type": "string" },
        "authorId": { "type": "string" },
        "authorName": { "type": "string" },
        "authorPhoto": { "type": "string" },
        "content": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["postId", "authorId", "authorName", "content", "createdAt"]
    },
    "Like": {
      "title": "Like",
      "description": "A like on a post.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "postId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "postId", "createdAt"]
    },
    "Ad": {
      "title": "Ad",
      "description": "User advertisement.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "imageUrl": { "type": "string" },
        "linkUrl": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "approved", "rejected"] },
        "isActive": { "type": "boolean" },
        "targetAgeMin": { "type": "number" },
        "targetAgeMax": { "type": "number" },
        "targetCountry": { "type": "string" },
        "targetCity": { "type": "string" },
        "targetCategory": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "title", "description", "status", "isActive", "createdAt"]
    },
    "AdminMessage": {
      "title": "AdminMessage",
      "description": "Messages from admin to users.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "subject": { "type": "string" },
        "content": { "type": "string" },
        "isRead": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "subject", "content", "isRead", "createdAt"]
    },
    "Chat": {
      "title": "Chat",
      "description": "A 1-on-1 chat conversation.",
      "type": "object",
      "properties": {
        "participantIds": { "type": "array", "items": { "type": "string" } },
        "lastMessage": { "type": "string" },
        "lastMessageTime": { "type": "string", "format": "date-time" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["participantIds", "createdAt"]
    },
    "ChatMessage": {
      "title": "ChatMessage",
      "description": "A message within a chat.",
      "type": "object",
      "properties": {
        "chatId": { "type": "string" },
        "senderId": { "type": "string" },
        "text": { "type": "string" },
        "isRead": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["chatId", "senderId", "text", "isRead", "createdAt"]
    }
  },
  "firestore": {
    "/users_private/{userId}": {
      "schema": { "$ref": "#/entities/PrivateUser" },
      "description": "Stores private user data and settings."
    },
    "/public_profiles/{userId}": {
      "schema": { "$ref": "#/entities/PublicProfile" },
      "description": "Stores public user profiles."
    },
    "/posts/{postId}": {
      "schema": { "$ref": "#/entities/Post" },
      "description": "Stores life lesson posts."
    },
    "/comments/{commentId}": {
      "schema": { "$ref": "#/entities/Comment" },
      "description": "Stores comments on posts."
    },
    "/likes/{likeId}": {
      "schema": { "$ref": "#/entities/Like" },
      "description": "Stores likes on posts. Document ID should be userId_postId."
    },
    "/ads/{adId}": {
      "schema": { "$ref": "#/entities/Ad" },
      "description": "Stores user advertisements."
    },
    "/admin_messages/{messageId}": {
      "schema": { "$ref": "#/entities/AdminMessage" },
      "description": "Stores messages from admins to users."
    },
    "/chats/{chatId}": {
      "schema": { "$ref": "#/entities/Chat" },
      "description": "Stores chat conversations."
    },
    "/chats/{chatId}/messages/{messageId}": {
      "schema": { "$ref": "#/entities/ChatMessage" },
      "description": "Stores messages within a chat."
    }
  }
}
